APP_NAME=OutboundEngine
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (MySQL; service name "mysql" matches the Docker stack added in Phase 1) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=outboundengine
DB_USERNAME=outboundengine
DB_PASSWORD=secret

# --- Sessions / cache / queue (Redis service name "redis" matches the Docker stack) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (the APP does not send prospect email; Instantly/Lemlist do. This is internal notices only) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Object storage for proof assets / landing pages (optional; FILESYSTEM_DISK=s3 to enable) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =====================================================================
# OutboundEngine integrations — populated per phase as each lands.
# Listed here up front as the roadmap; keys are inert until their phase.
# =====================================================================

# Phase 2 — Product Brain (LLM that reads your decks/site and writes copy)
ANTHROPIC_API_KEY=
OE_LLM_MODEL=claude-sonnet-4-6

# Phase 3 — Lead pipeline: email verification (provider-agnostic)
OE_VERIFY_PROVIDER=
OE_VERIFY_API_KEY=

# Phase 6 — Sending platforms (both live behind one adapter; pick the default)
OE_OUTBOUND_PROVIDER=instantly
INSTANTLY_API_KEY=
LEMLIST_API_KEY=

# Phase 2+ (later) — Apollo as an automatic lead source (CSV is the v1 source)
APOLLO_API_KEY=
